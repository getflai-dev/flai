# FlAI Maestro Test Credentials
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# These credentials are used by the Maestro E2E tests to authenticate
# against your backend. The .env file is gitignored — never commit real credentials.

FLAI_TEST_EMAIL=your-email@example.com
FLAI_TEST_PASSWORD=your-password-here
